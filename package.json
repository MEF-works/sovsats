{
  "name": "sovsats",
  "version": "0.2.1",
  "description": "SovSats — Checkout Without Compromise. A drop-in Bitcoin checkout UI for BTCPay Server.",
  "author": "MEFworks",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MEF-works/sovsats.git"
  },
  "homepage": "https://sovsats.com/",
  "bugs": {
    "url": "https://github.com/MEF-works/sovsats/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "btcpay",
    "bitcoin",
    "checkout",
    "crypto",
    "payments",
    "high-risk",
    "kratom",
    "cbd",
    "nootropics"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.mjs",
      "require": "./dist/react/index.js"
    },
    "./adapters/next": {
      "types": "./dist/adapters/next/index.d.ts",
      "import": "./dist/adapters/next/index.mjs",
      "require": "./dist/adapters/next/index.js"
    },
    "./adapters/express": {
      "types": "./dist/adapters/express/index.d.ts",
      "import": "./dist/adapters/express/index.mjs",
      "require": "./dist/adapters/express/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "peerDependencies": {
    "framer-motion": ">=10",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "framer-motion": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^4",
    "@types/node": "^20.19.37",
    "@types/react": "^18",
    "framer-motion": "^12.37.0",
    "next": "^16.1.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
